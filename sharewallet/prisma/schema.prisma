generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id                          String    @id @default(cuid())
  fullName                    String
  email                       String
  phoneNo                     Int
  password                    String
  username                    String    @unique
  role                        Role      @default(USER)
  createdAt                   DateTime  @default(now())
  members                     Group_members[]
  notification                notifications[]
  emergency_vote              emergency_vote[]
  transactions                transactions[]
  emergency_fund_requests     emergency_fund_requests[]
  contributions               contributions[]
}

model Group{
  id                          String      @id @default(cuid())
  groupName                   String
  description                 String
  monthlyContribution         Int
  minimum_member              Int
  contribution_deadline       DateTime
  withdrawal_conditions       String
  role                        Group_Role  @default(ADMIN)
  members                     Group_members[]
  chatMessage                 chat_message[]
  transactions                transactions[]
  emergency_fund_requests     emergency_fund_requests[]
  contributions               contributions[]
}

model Group_members{
  id                                    String     @id @default(cuid())
  user_id                               String
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                              String      @unique
  group                                 Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  role                                  Group_Role  @default(MEMBER)
  
}

model contributions{
  id                                    String @id @default(cuid())
  amount                                Int
  month                                 Int
  year                                  Int
  status                                status    @default(PENDING)
  //TRANSACTION_ID  LEFT
  user_id                               String
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                              String      @unique
  group                                 Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
}

model emergency_fund_requests{
  id                                    String @id @default(cuid())
  reason                                String
  amount_requested                      Int
  emergency_status                      emergency_status  @default(PENDING)
  cretaed_at                            DateTime  @default(now())
  user_id                               String
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                              String      @unique
  group                                 Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  emergency                             emergency_vote[]
}

model transactions{
  id                                  String @id @default(cuid())
  type                                transaction_type   
  amount                              Int
  reference_id                        String @default(cuid())
  created_at                          DateTime @default(now())
  group_id                            String      @unique
  group                               Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  user_id                             String
  user                                User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
}

model emergency_vote{
  id                                  String @id @default(cuid())
  request_id                          String
  emergency_fund_requests             emergency_fund_requests      @relation(fields: [request_id],references: [id],onDelete: Cascade)
  user_id                             String
  user                                User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  vote                                vote
  voted_at                            DateTime @default(now())  
}

model notifications{
  id                                  String @id @default(cuid())
  user_id                             String
  user                                User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  title                               String
  body                                String
  type                                String
  is_read                             Boolean
  created_at                          DateTime @default(now())
}

model chat_message{
  id                                  String @id @default(cuid())
  // sender_id
  group_id                            String
  group                               Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  message                             String
  type                                chat_type
  created_at                          DateTime @default(now())
}

enum  chat_type{
  TEXT
  IMAGE
  SYSTEM
}

enum vote{
  APPROVE
  REJECT
}

enum  Group_Role{
  ADMIN
  MEMBER
}

enum  Role{
  USER
  ADMIN
  MODERATOR
}

enum status{
  PENDING
  SUCCESS
  FAILED
}

enum emergency_status{
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum transaction_type{
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}