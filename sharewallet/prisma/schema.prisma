generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id                                    String              @id @default(cuid())
  email                                 String              @unique
  password                              String
  isVerified                            Boolean             @default(false)
  role                                  Role                @default(USER)
  createdAt                             DateTime            @default(now())
  uniqueuserCode                        String?              @unique
  members                               GroupMembers[]
  notification                          Notification[]
  emergency_vote                        EmergencyVote[]
  transactions                          Transactions[]
  emergency_fund_requests               EmergencyFundRequest[]
  contributions                         Contributions[]
  userDetails                           UserDetails?
  sender_id                             ChatMessage[]
  sentRequests                          FriendRequest[] @relation("SentRequests")
  receivedRequests                      FriendRequest[] @relation("ReceivedRequests")
  friends          User[]               @relation("UserFriends")
  friendOf         User[]               @relation("UserFriends")
}

model FriendRequest {
  id                                    String            @id @default(cuid())
  senderId                              String
  receiverId                            String
  status                                String            @default("PENDING")
  createdAt                             DateTime          @default(now())
  sender                                User              @relation("SentRequests", fields: [senderId], references: [id])
  receiver                              User              @relation("ReceivedRequests", fields: [receiverId], references: [id])
  @@unique([senderId, receiverId])
}
model UserDetails{
  id                                    String              @id @default(cuid())
  fullName                              String
  phoneNo                               String
  username                              String
  user_id                               String    @unique
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
}

model Group{
  id                          String      @id @default(cuid())
  groupName                   String
  description                 String
  monthlyContribution         Int
  minimum_member              Int
  contribution_deadline       DateTime?
  withdrawal_conditions       String
  role                        Group_Role  @default(ADMIN)
  members                     GroupMembers[]
  chatMessage                 ChatMessage[]
  transactions                Transactions[]
  emergency_fund_requests     EmergencyFundRequest[]
  contributions               Contributions[]
}

model GroupMembers{
  id                                    String      @id @default(cuid())
  user_id                               String
  user                                  User        @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                              String      
  group                                 Group       @relation(fields: [group_id],references: [id],onDelete: Cascade)
  role                                  Group_Role  @default(MEMBER)
  @@unique([user_id, group_id])
}

model Contributions{
  id                                    String @id @default(cuid())
  amount                                Int
  month                                 Int
  year                                  Int
  status                                status    @default(PENDING)
  //TRANSACTION_ID  LEFT
  user_id                               String
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                              String      @unique
  group                                 Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
}

model EmergencyFundRequest{
  id                                    String @id @default(cuid())
  reason                                String
  amount_requested                      Int
  emergency_status                      emergency_status  @default(PENDING)
  created_at                            DateTime  @default(now())
  user_id                               String
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                              String      @unique
  group                                 Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  emergency                             EmergencyVote[]
}

model Transactions{
  id                                  String @id @default(cuid())
  type                                transaction_type   
  amount                              Int
  reference_id                        String @default(cuid())
  created_at                          DateTime @default(now())
  group_id                            String      @unique
  group                               Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  user_id                             String
  user                                User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
}

model EmergencyVote{
  id                                  String @id @default(cuid())
  request_id                          String
  emergency_fund_requests             EmergencyFundRequest      @relation(fields: [request_id],references: [id],onDelete: Cascade)
  user_id                             String
  user                                User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  vote                                vote
  voted_at                            DateTime @default(now())  
}

model Notification{
  id                                  String @id @default(cuid())
  user_id                             String
  user                                User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  title                               String
  body                                String
  type                                String
  is_read                             Boolean       @default(false)
  created_at                          DateTime @default(now())
}

model ChatMessage{
  id                                  String @id @default(cuid())
  user_id                               String    @unique
  user                                  User       @relation(fields: [user_id],references: [id],onDelete: Cascade)
  group_id                            String
  group                               Group      @relation(fields: [group_id],references: [id],onDelete: Cascade)
  message                             String
  type                                chat_type
  created_at                          DateTime @default(now())
}

enum  chat_type{
  TEXT
  IMAGE
  SYSTEM
}

enum vote{
  APPROVE
  REJECT
}

enum  Group_Role{
  ADMIN
  MEMBER
}

enum  Role{
  USER
  ADMIN
  MODERATOR
}

enum status{
  PENDING
  SUCCESS
  FAILED
}

enum emergency_status{
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum transaction_type{
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}